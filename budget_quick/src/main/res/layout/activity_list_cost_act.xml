<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:fab="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    tools:context=".CostActActivity">

    <include
        android:id="@+id/appbar_cost_act"
        layout="@layout/toolbar_action_bar"/>

    <Spinner
        android:id="@+id/spinner_rooms"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="@dimen/activity_vertical_margin"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingVertical="@dimen/activity_vertical_margin"
        android:paddingHorizontal="@dimen/activity_horizontal_margin">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcview_cost_act_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
        </androidx.recyclerview.widget.RecyclerView>

        <com.scalified.fab.ActionButton
            android:id="@+id/fab_add_cost_a"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:visibility="invisible"
            fab:type="DEFAULT"
            fab:image="@drawable/ic_add"
            fab:button_color="@color/colorAccent"
            fab:button_colorPressed="@color/colorLightAccent"
            fab:shadowResponsiveEffect_enabled="true"
            fab:rippleEffect_enabled="true"
            fab:button_colorRipple="@color/colorAccent"
            fab:show_animation="@anim/fab_jump_from_down"
            fab:hide_animation="@anim/fab_jump_to_down"/>
    </FrameLayout>
</LinearLayout>
