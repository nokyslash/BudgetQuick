<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cv_activity"
    android:layout_height="wrap_content"
    android:layout_width="match_parent"
    android:layout_marginTop="@dimen/cardview_margin_bottom"
    card_view:cardBackgroundColor="@color/colorCardViewBackground"
    card_view:cardCornerRadius="@dimen/cardview_corner_radius" >

    <com.andexert.library.RippleView
        android:id="@+id/rppv_act_backg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:rv_rippleDuration="100">

        <RelativeLayout
            android:id="@+id/relative_layout_background_act"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/cardview_padding">

            <TextView
                android:id="@+id/txview_title_act"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_centerHorizontal="true"
                android:textAppearance="?android:attr/textAppearanceLarge"
                style="@style/TitleCardViewActivity" />

            <TextView
                android:id="@+id/txview_price_act"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/txview_title_act"
                android:layout_alignParentStart="true"
                android:textAppearance="?android:attr/textAppearanceSmall" />

            <TextView
                android:id="@+id/txview_um_act"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/txview_title_act"
                android:layout_alignParentEnd="true"
                android:textAppearance="?android:attr/textAppearanceSmall" />
        </RelativeLayout>
    </com.andexert.library.RippleView>
</androidx.cardview.widget.CardView>