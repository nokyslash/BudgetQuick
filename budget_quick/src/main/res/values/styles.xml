<resources>

    <!-- Base application theme. -->
    <style name="CustomAppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:colorBackground">@color/colorBackground</item>
    </style>

    <!--CardView's Elements Style-->
    <!--CardViewProject-->
    <style name="TitleCardViewProject">
        <item name="android:textColor">@color/colorAccent</item>
    </style>

    <style name="SubtitleCardViewProject">
        <item name="android:layout_marginStart">@dimen/cardview_subtitle_margin_left</item>
    </style>

    <!--CardViewActivity-->
    <style name="TitleCardViewActivity">
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:textSize">@dimen/cardview_title_text_size</item>
        <item name="android:layout_marginBottom">@dimen/cardview_act_title_margin_bottom</item>
        <item name="android:textAlignment">center</item>
    </style>

    <!--CardViewAssignedActivity-->
    <style name="DualityCardViewAssignedActivity">
        <item name="android:textSize">@dimen/cardview_index_text_size</item>
    </style>

    <!-- CardView Notes-->
    <style name="StyleIndexNotes">
        <item name="android:textSize">@dimen/cardview_index_text_size2</item>
        <item name="android:textColor">@color/colorAccent</item>
    </style>

    <!--Other-->
    <style name="link_appearance">
        <item name="android:textStyle">italic</item>
        <item name="android:textColor">@color/colorLink</item>
    </style>

    <style name="textview_version">
        <item name="android:textSize">25sp</item>
        <item name="android:layout_marginBottom">@dimen/activity_vertical_margin</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="textview_app_name">
        <item name="android:textSize">45sp</item>
        <item name="android:layout_marginBottom">@dimen/activity_vertical_margin</item>
        <item name="android:layout_marginStart">@dimen/activity_vertical_margin_small</item>
        <item name="android:layout_marginEnd">@dimen/activity_vertical_margin_small</item>
        <item name="android:layout_marginTop">@dimen/elements_insert_act_margin_vertical</item>
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="textview_app_name_splash">
        <item name="android:textSize">45sp</item>
        <item name="android:layout_marginBottom">@dimen/activity_vertical_margin</item>
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:textAlignment">center</item>
    </style>

    <!-- You can also inherit from NNF_BaseTheme.Light -->
    <style name="FilePickerTheme" parent="NNF_BaseTheme">
        <!-- Set these to match your theme -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Setting a divider is entirely optional -->
        <item name="nnf_list_item_divider">?android:attr/listDivider</item>

        <!-- Need to set this also to style create folder dialog -->
        <item name="alertDialogTheme">@style/FilePickerAlertDialogTheme</item>

        <!-- If you want to set a specific toolbar theme, do it here -->
        <!-- <item name="nnf_toolbarTheme">@style/ThemeOverlay.AppCompat.Dark.ActionBar</item> -->
    </style>

    <style name="FilePickerAlertDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>
</resources>
