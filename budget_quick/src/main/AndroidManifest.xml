<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/CustomAppTheme"
        tools:ignore="AllowBackup,GoogleAppIndexingWarning">
        <activity android:name=".MainActivity" />
        <activity android:name=".CostActActivity" />
        <activity android:name=".ExpenseMatActivity" />
        <activity android:name=".SummaryCostActivity" />
        <activity android:name=".SummaryExpenseActivity" />
        <activity android:name=".ContactActivity" />
        <activity
            android:name=".InsertProjectActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".EditProjectActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".InsertActActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".EditActActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".InsertMaterialActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".EditMaterialActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".InsertCostActActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".EditCostActActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".InsertExpenseMatActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".EditExpenseMatActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".AboutActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".NotesActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".InsertContactActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".EditContactActivity"
            android:screenOrientation="fullSensor" />
        <activity
            android:name=".StartActivity"
            android:screenOrientation="fullSensor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/nnf_provider_paths" />
        </provider>
        <activity
            android:name="com.nononsenseapps.filepicker.FilePickerActivity"
            android:label="@string/app_name"
            android:theme="@style/FilePickerTheme">
            <intent-filter>
                <action android:name="android.intent.action.GET_CONTENT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
    </application>
</manifest>
